// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  icon     String
  products Product[]
}

model Product {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String
  price       Float
  stock       Int
  ageGroup    String         // e.g. "3-5", "6-8", "9-10"
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  thumbnail   String
  benefits    String         // comma-separated list of benefits, e.g. "Creativity, Motor Skills"
  images      ProductImage[]
  orderItems  OrderItem[]
  createdAt   DateTime       @default(now())
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
}

model Order {
  id            String               @id @default(uuid())
  trackingId    String               @unique
  customerName  String
  phone         String
  address       String
  status        String               // "PLACED", "CONFIRMED", "PACKED", "SHIPPED", "DELIVERED", "CANCELLED"
  total         Float
  createdAt     DateTime             @default(now())
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  createdAt DateTime @default(now())
}
